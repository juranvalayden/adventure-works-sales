    {
      "name": "PUT-sales-order-header",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Generate a random 15-character alphanumeric string\r",
              "function generateApprovalCode(length) {\r",
              "    const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789';\r",
              "    let result = '';\r",
              "    for (let i = 0; i < length; i++) {\r",
              "        result += chars.charAt(Math.floor(Math.random() * chars.length));\r",
              "    }\r",
              "    return result;\r",
              "}\r",
              "\r",
              "// Build the payload object\r",
              "const payload = {\r",
              "    creditCardApprovalCode: generateApprovalCode(15),\r",
              "    comment: \":) Using PUT - modified at \" + new Date().toISOString()\r",
              "};\r",
              "\r",
              "// Save the payload as a stringified variable\r",
              "pm.variables.set(\"salesOrderPayload\", JSON.stringify(payload));"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "noauth"
        },
        "method": "PUT",
        "header": [],
        "body": {
          "mode": "raw",
