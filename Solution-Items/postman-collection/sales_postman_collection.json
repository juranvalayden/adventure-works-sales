    {
      "name": "PATCH-sales-order-header",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "function generateApprovalCode(length) {\r",
              "    const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789';\r",
              "    let result = '';\r",
              "    for (let i = 0; i < length; i++) {\r",
              "        result += chars.charAt(Math.floor(Math.random() * chars.length));\r",
              "    }\r",
              "    return result;\r",
              "}\r",
              "\r",
              "const patchPayload = [\r",
              "    {\r",
              "        op: \"replace\",\r",
              "        path: \"/creditCardApprovalCode\",\r",
              "        value: generateApprovalCode(15)\r",
              "    },\r",
              "    {\r",
              "        op: \"replace\",\r",
              "        path: \"/comment\",        \r",
              "        value: \";) Using PATCH - modified at \" + new Date().toISOString()\r",
              "    }\r",
              "];\r",
              "\r",
              "pm.variables.set(\"salesOrderPatchPayload\", JSON.stringify(patchPayload));"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
